var activeTab     = TABS[0];
var activeSection = SECTIONS[0];

function resolveColour(c) {
  return COLOURS[c] || c;
}

function isLight(hex) {
  if (!hex || hex.length < 7) return false;
  var r = parseInt(hex.slice(1, 3), 16),
      g = parseInt(hex.slice(3, 5), 16),
      b = parseInt(hex.slice(5, 7), 16);
  return (r * 299 + g * 587 + b * 114) / 1000 > 155;
}

// Only show sidebar sections that have at least one proforma for the current tab
function availableSections(tab) {
  return SECTIONS.filter(function(s) {
    return PROFORMAS.some(function(p) { return p.tab === tab && p.section === s; });
  });
}

function render() {
  var showAll = document.getElementById('pfAll').checked;
  var q       = document.getElementById('pfS').value.toLowerCase().trim();

  // Toggle label
  document.getElementById('pfToggleLbl').textContent = 'Show All ' + activeTab;

  // Top tabs
  document.getElementById('pfTabs').innerHTML = TABS.map(function(t) {
    return '<button class="pf-tab' + (t === activeTab ? ' pf-on' : '') +
           '" onclick="setTab(\'' + t + '\')">' + t + '</button>';
  }).join('');

  // Sidebar
  var secs = availableSections(activeTab);
  document.getElementById('pfSidebar').innerHTML = secs.map(function(s) {
    var esc = s.replace(/'/g, "\\'");
    return '<button class="pf-sec' + (s === activeSection && !showAll ? ' pf-on' : '') +
           '" onclick="setSec(\'' + esc + '\')">' + s + '</button>';
  }).join('');

  // Heading
  document.getElementById('pfHd').textContent =
    (showAll ? activeTab + ' — All proformas' : activeTab + ' — ' + activeSection) +
    (q ? '  ·  "' + q + '"' : '');

  // Filter
  var items = PROFORMAS.filter(function(p) {
    return p.tab === activeTab &&
           (showAll || p.section === activeSection) &&
           (!q || p.name.toLowerCase().indexOf(q) !== -1);
  });

  // Grid
  var grid = document.getElementById('pfGrid');
  if (items.length === 0) {
    grid.innerHTML = '<div class="pf-empty">No proformas found' +
      (q ? ' matching "' + q + '"' : '') + '.</div>';
  } else {
    grid.innerHTML = items.map(function(p) {
      var hex   = resolveColour(p.color);
      var light = isLight(hex);
      var style = 'background:' + hex + (light ? ';border:1.5px solid #ccc' : '');
      return '<a class="pf-tile' + (light ? ' pf-lt' : '') +
             '" style="' + style + '" href="' + p.url +
             '" target="_blank" rel="noopener noreferrer">' + p.name + '</a>';
    }).join('');
  }

  document.getElementById('pfCnt').textContent =
    items.length + ' proforma' + (items.length !== 1 ? 's' : '');
}

function setTab(tab) {
  activeTab = tab;
  var secs = availableSections(tab);
  activeSection = secs.length ? secs[0] : SECTIONS[0];
  document.getElementById('pfAll').checked = false;
  render();
}

function setSec(sec) {
  activeSection = sec;
  document.getElementById('pfAll').checked = false;
  render();
}

document.getElementById('pfS').addEventListener('input', render);
document.getElementById('pfAll').addEventListener('change', render);

render();
</script>
