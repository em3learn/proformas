  #pf-app .pf-empty {
    grid-column: 1 / -1;
    text-align: center;
    padding: 48px 16px;
    color: #90a4ae;
    font-size: 14px;
  }

  #pf-app .pf-count {
    margin-top: 10px;
    font-size: 13px;
    color: #9e9e9e;
  }

