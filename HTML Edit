    border-radius: 6px;
    background: white;
    color: #333;
    width: 240px;
    max-width: 100%;
    outline: none;
    font-family: inherit;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  #pf-app input.pf-search:focus {
    border-color: #1b5e20;
    box-shadow: 0 0 0 3px rgba(27, 94, 32, 0.1);
  }

  /* ── TILE GRID ───────────────────────────────────────────── */
  #pf-app .pf-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(148px, 1fr));
    gap: 9px;
  }

  #pf-app a.pf-tile {
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 16px 12px;
    min-height: 108px;
    border-radius: 7px;
    font-size: 15px;
    font-weight: 500;
    line-height: 1.4;
    color: white;
    text-decoration: none;
    cursor: pointer;
    transition: transform 0.12s, opacity 0.12s, box-shadow 0.12s;
    word-break: break-word;
    -webkit-hyphens: auto;
    hyphens: auto;
  }

  #pf-app a.pf-tile:hover {
    opacity: 0.87;
    transform: translateY(-2px);
    box-shadow: 0 6px 14px rgba(0, 0, 0, 0.18);
    text-decoration: none;
  }

